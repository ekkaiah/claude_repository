   "source": [
    "# Entrenament model reconeixement de cotxes\n",
    "**Dataset:** Stanford Cars (16.185 imatges, 196 classes marca+model+any)\n",
    "**Model:** EfficientNet-B3 (lleuger i precís)\n",
    "**GPU necessària:** T4 (Colab gratuït)\n",
    "**Temps estimat:** 1-2 hores\n",
    "\n",
    "### Com usar:\n",
    "1. Ves a `Runtime → Change runtime type → T4 GPU`\n",
    "2. Executa les cel·les en ordre\n",
    "3. Al final descarrega el model `model_cotxes.pth`"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ─── 1. Instal·lar dependències ───────────────────────────────────────────────\n",
    "!pip install -q datasets timm torchvision Pillow tqdm"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ─── 2. Verificar GPU ─────────────────────────────────────────────────────────\n",
    "import torch\n",
    "print(f'GPU disponible: {torch.cuda.is_available()}')\n",
    "print(f'GPU: {torch.cuda.get_device_name(0) if torch.cuda.is_available() else \"Cap\"}')\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ─── 3. Descarregar Stanford Cars des de Hugging Face ────────────────────────\n",
    "from datasets import load_dataset\n",
    "import json\n",
    "\n",
    "print('Descarregant Stanford Cars Dataset...')\n",
    "dataset = load_dataset('tanganke/stanford_cars')\n",
    "\n",
    "print(f'Train: {len(dataset[\"train\"])} imatges')\n",
    "print(f'Test:  {len(dataset[\"test\"])} imatges')\n",
    "\n",
    "# Obtenir els noms de les classes (marca+model+any)\n",
    "class_names = dataset['train'].features['label'].names\n",
    "num_classes = len(class_names)\n",
    "print(f'Classes: {num_classes}')\n",
    "print('Exemples de classes:')\n",
    "for c in class_names[:5]:\n",
    "    print(f'  - {c}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ─── 4. Preparar transformacions d'imatge ─────────────────────────────────────\n",
    "from torchvision import transforms\n",
    "from torch.utils.data import Dataset, DataLoader\n",
    "from PIL import Image\n",
    "import numpy as np\n",
    "\n",
    "IMG_SIZE = 300  # EfficientNet-B3 usa 300x300\n",
    "BATCH_SIZE = 32\n",
    "\n",
    "train_transforms = transforms.Compose([\n",
    "    transforms.Resize((IMG_SIZE, IMG_SIZE)),\n",
    "    transforms.RandomHorizontalFlip(),\n",
    "    transforms.RandomRotation(10),\n",
    "    transforms.ColorJitter(brightness=0.2, contrast=0.2, saturation=0.1),\n",
    "    transforms.ToTensor(),\n",
    "    transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])\n",
    "])\n",
    "\n",
    "val_transforms = transforms.Compose([\n",
    "    transforms.Resize((IMG_SIZE, IMG_SIZE)),\n",
    "    transforms.ToTensor(),\n",
    "    transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])\n",
    "])\n",
    "\n",
    "class CarsDataset(Dataset):\n",
    "    def __init__(self, hf_dataset, transform):\n",
    "        self.data = hf_dataset\n",
    "        self.transform = transform\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.data)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        item = self.data[idx]\n",
    "        image = item['image'].convert('RGB')\n",
    "        label = item['label']\n",
    "        return self.transform(image), label\n",
    "\n",
    "train_ds = CarsDataset(dataset['train'], train_transforms)\n",
    "val_ds   = CarsDataset(dataset['test'],  val_transforms)\n",
    "\n",
    "train_loader = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True,  num_workers=2)\n",
    "val_loader   = DataLoader(val_ds,   batch_size=BATCH_SIZE, shuffle=False, num_workers=2)\n",
    "\n",
    "print(f'Batches entrenament: {len(train_loader)}')\n",
    "print(f'Batches validació:   {len(val_loader)}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ─── 5. Carregar model EfficientNet-B3 pre-entrenat ───────────────────────────\n",
    "import timm\n",
    "import torch.nn as nn\n",
    "\n",
    "model = timm.create_model(\n",
    "    'efficientnet_b3',\n",
    "    pretrained=True,\n",
    "    num_classes=num_classes\n",
    ")\n",
    "model = model.to(device)\n",
    "\n",
    "# Comptar paràmetres\n",
    "params = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "print(f'Paràmetres entrenables: {params:,}')\n",
    "print(f'Model llest a: {device}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ─── 6. Configurar entrenament ────────────────────────────────────────────────\n",
    "import torch.optim as optim\n",
    "from torch.optim.lr_scheduler import CosineAnnealingLR\n",
    "\n",
    "EPOCHS = 20\n",
    "LR = 1e-3\n",
    "\n",
    "criterion = nn.CrossEntropyLoss(label_smoothing=0.1)\n",
    "optimizer = optim.AdamW(model.parameters(), lr=LR, weight_decay=1e-4)\n",
    "scheduler = CosineAnnealingLR(optimizer, T_max=EPOCHS)\n",
    "\n",
    "print(f'Epochs: {EPOCHS} | LR: {LR}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ─── 7. Entrenament ───────────────────────────────────────────────────────────\n",
    "from tqdm import tqdm\n",
    "\n",
    "best_acc = 0.0\n",
    "history = {'train_loss': [], 'val_acc': []}\n",
    "\n",
    "for epoch in range(EPOCHS):\n",
    "    # — Entrenament —\n",
    "    model.train()\n",
    "    running_loss = 0.0\n",
    "    for images, labels in tqdm(train_loader, desc=f'Epoch {epoch+1}/{EPOCHS}'):\n",
    "        images, labels = images.to(device), labels.to(device)\n",
    "        optimizer.zero_grad()\n",
    "        outputs = model(images)\n",
    "        loss = criterion(outputs, labels)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        running_loss += loss.item()\n",
    "\n",
    "    # — Validació —\n",
    "    model.eval()\n",
    "    correct = total = 0\n",
    "    with torch.no_grad():\n",
    "        for images, labels in val_loader:\n",
    "            images, labels = images.to(device), labels.to(device)\n",
    "            outputs = model(images)\n",
    "            _, predicted = outputs.max(1)\n",
    "            total += labels.size(0)\n",
    "            correct += predicted.eq(labels).sum().item()\n",
    "\n",
    "    val_acc = 100. * correct / total\n",
    "    avg_loss = running_loss / len(train_loader)\n",
    "    scheduler.step()\n",
    "\n",
    "    history['train_loss'].append(avg_loss)\n",
    "    history['val_acc'].append(val_acc)\n",
    "\n",
    "    print(f'Epoch {epoch+1:02}/{EPOCHS} | Loss: {avg_loss:.4f} | Val Acc: {val_acc:.2f}%')\n",
    "\n",
    "    # Guardar el millor model\n",
    "    if val_acc > best_acc:\n",
    "        best_acc = val_acc\n",
    "        torch.save({\n",
    "            'epoch': epoch,\n",
    "            'model_state_dict': model.state_dict(),\n",
    "            'val_acc': val_acc,\n",
    "            'class_names': class_names,\n",
    "            'num_classes': num_classes,\n",
    "        }, 'model_cotxes.pth')\n",
    "        print(f'  ✅ Nou millor model guardat! Acc: {val_acc:.2f}%')\n",
    "\n",
    "print(f'\\nMillor precisió: {best_acc:.2f}%')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ─── 8. Gràfic de resultats ───────────────────────────────────────────────────\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 4))\n",
    "ax1.plot(history['train_loss'])\n",
    "ax1.set_title('Pèrdua entrenament')\n",
    "ax1.set_xlabel('Epoch')\n",
    "ax2.plot(history['val_acc'], color='green')\n",
    "ax2.set_title('Precisió validació (%)')\n",
    "ax2.set_xlabel('Epoch')\n",
    "plt.tight_layout()\n",
    "plt.savefig('resultats_entrenament.png')\n",
    "plt.show()\n",
    "print(f'Millor precisió final: {best_acc:.2f}%')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ─── 9. Prova amb una imatge ──────────────────────────────────────────────────\n",
    "import requests\n",
    "from PIL import Image\n",
    "from io import BytesIO\n",
    "\n",
    "def identificar_cotxe(url_o_ruta, top_k=3):\n",
    "    # Carregar imatge\n",
    "    if url_o_ruta.startswith('http'):\n",
    "        r = requests.get(url_o_ruta)\n",
    "        img = Image.open(BytesIO(r.content)).convert('RGB')\n",
    "    else:\n",
    "        img = Image.open(url_o_ruta).convert('RGB')\n",
    "\n",
    "    # Preprocessar\n",
    "    tensor = val_transforms(img).unsqueeze(0).to(device)\n",
    "\n",
    "    # Predicció\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        outputs = model(tensor)\n",
    "        probs = torch.softmax(outputs, dim=1)\n",
    "        top_probs, top_idxs = probs.topk(top_k)\n",
    "\n",
    "    print('Top prediccions:')\n",
    "    for prob, idx in zip(top_probs[0], top_idxs[0]):\n",
    "        print(f'  {class_names[idx]:50s} {prob.item()*100:.1f}%')\n",
    "\n",
    "# Prova amb un cotxe de buscocotxe.ad\n",
    "identificar_cotxe('https://www.buscocotxe.ad/uploads/fotos_items/589619/1775942632_img_7378.jpeg')"
   ],
   "execution_count": null,
   "outputs": []
  },
